# ── Credenciales DMC (las mismas de Evergreen, NO se exponen al frontend) ──
DMC_USER=tu_usuario_dmc
DMC_TOKEN=tu_token_dmc

# ── Estación Isla Teja: confirmar el código con /api/dmc/cercanas ──
ESTACION_ISLA_TEJA=

# ── Supabase del proyecto Laguna (service role key: solo en el backend) ──
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service_role...

# ── CORS: dominios del frontend (Vercel + local) ──
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,null

# ── Parámetros de la laguna ──
LAGUNA_LAT=-39.8098
LAGUNA_LON=-73.2560
NIVEL_MIN_CM=0
NIVEL_MAX_CM=500
